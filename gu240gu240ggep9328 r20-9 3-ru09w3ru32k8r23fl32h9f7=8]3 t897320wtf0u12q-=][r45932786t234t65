-- ฟังก์ชันสร้างอักษรพิเศษ (Zalgo generator แบบจำลอง) ต่อท้ายอัตโนมัติ
local function generateZalgo(text, intensity)
    local upperMarks = {"̍", "̎", "̄", "̅", "͡", "͞", "͐", "̊", "̋", "̌", "̍", "̎"}
    local middleMarks = {"̶", "̷", "̸", "̢", "̢", "̧"}
    local lowerMarks = {"̖", "̗", "̘", "̙", "̜", "̝", "̞", "̟", "̠", "̤", "̥", "̦"}
    
    local result = text
    for i = 1, #text do
        local char = text:sub(i, i)
        local zalgoChunk = char
        for _ = 1, intensity do
            zalgoChunk = zalgoChunk .. upperMarks[math.random(#upperMarks)]
            zalgoChunk = zalgoChunk .. middleMarks[math.random(#middleMarks)]
            zalgoChunk = zalgoChunk .. lowerMarks[math.random(#lowerMarks)]
        end
        result = result:gsub(char, zalgoChunk, 1)
    end
    return result
end

playButton.MouseButton1Click:Connect(function()
    local musicId = idTextBox.Text
    if musicId ~= "" and event then
        pcall(function()
            local fakeMusicId = "97813398702843"
            -- สร้างข้อความอักษรพิเศษยุ่งเหยิงมาต่อท้าย ID เพื่อตบตาระบบกันดัก
            local rawSpam = "240HUB_BYPASS"
            local zalgoSpam = generateZalgo(rawSpam, 5)
            
            local payload = musicId .. "&" .. fakeMusicId .. "&" .. zalgoSpam
            event:FireServer("ToolMusicText", payload)
        end)
    end
end)

local userInputService = game:GetService("UserInputService")
local dragging, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging, dragStart, startPos = true, input.Position, mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
